programa {
  funcao inicio() {
  inteiro gasto=8000
  inteiro ftingressos=7500
  inteiro ftitens=5000
  real lucro
  lucro = ftingressos+ftitens-gasto
  escreva(lucro)
  escreva(" em reais")
  escreva("\n")
  real lucroporcentagem
  lucroporcentagem = lucro*100/gasto
  escreva(lucroporcentagem)
  escreva(" em porcentagem")

  
    
  }
}

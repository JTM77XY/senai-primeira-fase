programa {
  funcao inicio() {
  inteiro distanciaKMtotal
  real combustiveltotal
  real consumomedio
  escreva("digite o valor da  distância percorrida:")
  leia(distanciaKMtotal)
  escreva("digite o valor do  combustivel gasto:")
  leia(combustiveltotal)


  consumomedio=distanciaKMtotal/combustiveltotal
  escreva(consumomedio)  
  }
}

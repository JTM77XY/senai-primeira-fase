programa {
  funcao inicio() {
  inteiro horatrabalhada
  real cobranca1=350.00
  real cobranca2=500.00

  escreva("horas trabalhadas:")
  leia(horatrabalhada)

  horatrabalhada*cobranca1+cobranca2
  escreva("R$")
  escreva(horatrabalhada*cobranca1+cobranca2)
  escreva(" cobrados")
  escreva("\n")
  horatrabalhada*cobranca1
  escreva("R$")
  escreva(horatrabalhada*cobranca1)
  escreva(" de lucro")
  }
}

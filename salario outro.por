programa {
  funcao inicio() {
  inteiro id
  inteiro horastrabalhadas
  real valorhora
  real salario

  escreva("id do funcionario:")
  leia(id)
  
  escreva("horas trabalhadas:")  
  leia(horastrabalhadas)
  
  escreva("valor por hora:")
  leia(valorhora)

  salario=horastrabalhadas*valorhora
  escreva("U$")
  escreva(salario)

  }
}

programa {
  funcao inicio() {
  inteiro numero
  escreva("digite um número de 1 a 7:")
  leia(numero)

  se(numero==1){
    escreva("domingo")
    }

    se(numero==2){
      escreva("segunda")
      }

    se(numero==3){
      escreva("terça")
    } 

    se(numero==4){
      escreva("quarta")
    }

    se(numero==5){
      escreva("qunta")
    }

    se(numero==6){
      escreva("sexta")
    }

    se(numero==7){
      escreva("sábado")
    } 

  }
}

programa {
  funcao inicio() {
   real valorA
   real valorB
   real valorC
   real soma
   inteiro somadospesos=10
   real media
   escreva("escreva a primeira nota:")
   leia(valorA)
   escreva("escreva a segunda nota:")
   leia(valorB)
   escreva("escreva a terceira nota:")
   leia(valorC)

   soma= valorA*2+valorB*3+valorC*5
   media=soma/somadospesos
   escreva(media)



   
  }
}

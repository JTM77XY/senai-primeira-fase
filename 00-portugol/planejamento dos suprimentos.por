programa {
  funcao inicio() {
  inteiro show
  inteiro bombas=7
  real precodabomba
  real dinheiro
  escreva("quantos shows voce vai fazer:")
  leia(show)
  escreva( "qual o preco de cada bomba:")
  leia(precodabomba)

dinheiro = show*bombas*precodabomba
escreva("o dinheiro que voce precisa para comprar as bombas é R$" + dinheiro)
 



  }
}

programa {
  funcao inicio() {
   cadeia tamanho
   inteiro valor=10, valor2=20, valor3=30
   escreva("digite o tamanho da pizza (p/m/g):")
   leia(tamanho)
   se(tamanho=="p"){
    escreva("R$"+valor)
   }senao{
    se(tamanho=="m"){
      escreva("R$"+valor2)
    }senao{
      se(tamanho=="g"){
        escreva("R$"+valor3)
      }
    }
   }
   
   
   
  }
}

programa {
  funcao inicio() {
  inteiro tok    
  inteiro prompt
  inteiro custodoprompt=5


  escreva("qual é o número de prompt:")
  leia(prompt)
  escreva("qual o número de caracter do prompt:")
  leia(tok)

  prompt*custodoprompt+prompt*tok
  escreva(prompt*custodoprompt+prompt*tok)
  escreva(" tokens")








  





    
  }
}

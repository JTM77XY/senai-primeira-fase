programa {
  funcao inicio() {
  inteiro numeroA
  inteiro numeroB

  escreva("digite o primeiro número:")
  leia(numeroA)
  escreva("digite o segundo número:")
  leia(numeroB)

 se(numeroA>numeroB){
  escreva("o primeiro número é o maior")
 }senao{
  se(numeroB>numeroA){
    escreva("o segundo número é o maior")
  }senao{
    escreva("os dois são iguais")
  }
 }


  
  
 

 
  

  }
}

programa {
  funcao inicio() {
  inteiro custodoprompt=5
  inteiro custodocaracter=1
  inteiro prompt
  real tokens
  real custo
  inteiro valordotoken
  escreva("qual o numero de caracter do prompt:")
  leia(prompt)
  escreva("\n")
  escreva("quanto custa o prompt:")
  leia(custo)




  tokens = prompt*custodocaracter+custodoprompt
  escreva(tokens)
  escreva(" tokens")
  escreva("\n")
  valordotoken=custo*tokens
  escreva(valordotoken)
  escreva(" R$")









  





    
  }
}
